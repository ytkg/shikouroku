{
  "name": "@shikouroku/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npm --workspace @shikouroku/web run build && wrangler dev",
    "dev:remote": "npm --workspace @shikouroku/web run build && wrangler dev --remote",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:architecture": "vitest run tests/architecture",
    "test:unit": "vitest run tests/unit",
    "test:contract": "vitest run tests/contract",
    "test:integration": "vitest run tests/integration",
    "check": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "d1:migrate:dev": "wrangler d1 migrations apply shikouroku-prod --remote --preview",
    "d1:migrate:prod": "wrangler d1 migrations apply shikouroku-prod --remote",
    "d1:seed:dev": "wrangler d1 execute shikouroku-prod --remote --preview --file=./seeds/dev.sql",
    "d1:seed:prod": "wrangler d1 execute shikouroku-prod --remote --file=./seeds/prod.sql",
    "d1:tables:dev": "wrangler d1 execute shikouroku-prod --remote --preview --command \"SELECT name FROM sqlite_master WHERE type='table' ORDER BY name;\"",
    "d1:tables:prod": "wrangler d1 execute shikouroku-prod --remote --command \"SELECT name FROM sqlite_master WHERE type='table' ORDER BY name;\""
  },
  "dependencies": {
    "hono": "^4.12.5",
    "vite": "7.3.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260307.1",
    "@vitest/coverage-v8": "^4.0.18",
    "typescript": "^5.6.3",
    "wrangler": "^4.71.0"
  }
}
